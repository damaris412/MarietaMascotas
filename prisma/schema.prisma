generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

enum Locality {
  VILLA_MARIA
  VILLA_NUEVA
  OTRA
}

enum Size {
  S
  M
  L
}

enum PaymentStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum PaymentMethod {
  MERCADO_PAGO_CARD
  MERCADO_PAGO_PSE
  MERCADO_PAGO_CASH
  OTHER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT)

  address  String?
  locality Locality?
  phone    String?

  accounts Account[]
  sessions Session[]
  orders   Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  products Product[]
}

model Product {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String   @db.Text
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  price         Decimal  @db.Decimal(10, 2)
  previousPrice Decimal? @db.Decimal(10, 2)
  images        String[]
  stock         Int      @default(0)
  sizes         Size[]
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  featured      Boolean  @default(false)
  active        Boolean  @default(true)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model Order {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id])

  guestName    String?
  guestEmail   String?
  guestDni     String?
  guestAddress String?
  guestPhone   String?

  locality Locality?

  status            PaymentStatus  @default(PENDING)
  paymentMethod     PaymentMethod?
  shippingCost      Decimal        @db.Decimal(10, 2) @default(0)
  total             Decimal        @db.Decimal(10, 2)
  whatsappContacted Boolean        @default(false)

  mpPreferenceId String?
  mpPaymentId    String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paidAt    DateTime?

  @@index([status])
  @@index([createdAt])
}

model StoreSettings {
  id                     String   @id @default("singleton")
  shippingCost           Decimal  @db.Decimal(10, 2) @default(15000)
  freeShippingThreshold  Decimal  @db.Decimal(10, 2) @default(250000)
  updatedAt              DateTime @updatedAt
}

enum ApplicationArea {
  MARKETING
  CATALOGO_FOTOS
  IMAGENES_IA
  FLETE_ENVIOS
  COLABORACIONES
  EVENTOS
  PACKAGING
  OTRO
}

model JobApplication {
  id        String           @id @default(cuid())
  name      String
  email     String
  phone     String
  area      ApplicationArea
  message   String           @db.Text
  resumeUrl String?

  emailSent Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([createdAt])
}

model CustomOrderRequest {
  id String @id @default(cuid())

  ownerName  String
  ownerEmail String
  ownerPhone String

  petName  String
  petAge   String
  petBreed String

  neckCm       Decimal @db.Decimal(5, 1)
  chestCm      Decimal @db.Decimal(5, 1)
  backLengthCm Decimal @db.Decimal(5, 1)

  eventName String?
  notes     String? @db.Text

  fabricMediaUrls String[]
  petMediaUrls    String[]

  contacted Boolean @default(false)
  emailSent Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  title    String
  price    Decimal @db.Decimal(10, 2)
  quantity Int
  size     Size?

  @@index([orderId])
  @@index([productId])
}
