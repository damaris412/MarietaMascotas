# ============================================================
# Variables de entorno centralizadas — Marieta Mascotas
# Copia este archivo a ".env" y completa los valores reales.
# Usado tanto por "npm run dev" (local) como por docker-compose.
# ============================================================

# --- Base de datos ---
# Credenciales discretas: las usa el contenedor de Postgres (docker-compose)
# para inicializar el usuario/base de datos.
POSTGRES_USER="marieta"
POSTGRES_PASSWORD="marieta"
POSTGRES_DB="marieta_mascotas"

# Cadena de conexión que usa Prisma. Para desarrollo local con "npm run dev"
# (Postgres corriendo en el host o publicado en un puerto local), usa
# 127.0.0.1 y el puerto publicado. docker-compose.yml sobrescribe esta
# variable automáticamente al host interno "db" cuando la app corre
# dentro del propio stack de contenedores — no necesitas cambiar nada aquí.
DATABASE_URL="postgresql://marieta:marieta@127.0.0.1:5433/marieta_mascotas?schema=public"

# --- NextAuth (Auth.js) ---
AUTH_SECRET="genera-uno-con: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\""
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email que, la primera vez que inicia sesión con Google, queda como ADMIN
# automáticamente (panel /admin). Cualquier otro email queda como CLIENT.
ADMIN_EMAIL=""

# --- Mercado Pago ---
MERCADOPAGO_ACCESS_TOKEN=""
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""
# Clave secreta de firma del webhook: Panel de Mercado Pago > Tu integración
# > Webhooks > "Firma secreta". Sin esto, en producción se rechazan todas
# las notificaciones (por seguridad).
MERCADOPAGO_WEBHOOK_SECRET=""

# --- URL pública del sitio (back_urls y notification_url de Mercado Pago) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- WhatsApp del negocio ---
# Número completo en formato internacional para wa.me, SIN "+" ni espacios
# ni guiones. Para Argentina: 54 9 <código de área sin 0> <número sin 15>.
# Ej. un celular de Villa María (0353) 15-123-4567 sería: 5493534123456
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# --- Envío de correos (confirmación de "Trabajá con nosotros") ---
# Gmail del negocio + "Contraseña de aplicación" (NO la contraseña normal):
# generála en https://myaccount.google.com/apppasswords (requiere tener
# activada la verificación en 2 pasos en esa cuenta de Gmail).
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
